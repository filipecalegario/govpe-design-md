{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Design system do Governo do Estado de Pernambuco para serviços digitais",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0.204,
          0.718
        ],
        "hex": "#0034b7"
      }
    },
    "primary-strong": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0.102,
          0.478
        ],
        "hex": "#001a7a"
      }
    },
    "primary-surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.902,
          0.953,
          1
        ],
        "hex": "#e6f3ff"
      }
    },
    "secondary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.286,
          0.298,
          0.341
        ],
        "hex": "#494c57"
      }
    },
    "neutral": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.973,
          0.98,
          0.988
        ],
        "hex": "#f8fafc"
      }
    },
    "neutral-soft": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.906,
          0.914,
          0.922
        ],
        "hex": "#e7e9eb"
      }
    },
    "neutral-medium": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.808,
          0.824,
          0.843
        ],
        "hex": "#ced2d7"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          1,
          1
        ],
        "hex": "#ffffff"
      }
    },
    "on-surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.157,
          0.153,
          0.173
        ],
        "hex": "#28272c"
      }
    },
    "danger": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.675,
          0.063,
          0.063
        ],
        "hex": "#ac1010"
      }
    },
    "danger-strong": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.518,
          0.114,
          0.114
        ],
        "hex": "#841d1d"
      }
    },
    "danger-surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          0.894,
          0.894
        ],
        "hex": "#ffe4e4"
      }
    },
    "success": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.169,
          0.392,
          0.094
        ],
        "hex": "#2b6418"
      }
    },
    "success-strong": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.071,
          0.251,
          0.051
        ],
        "hex": "#12400d"
      }
    },
    "success-surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.918,
          0.984,
          0.843
        ],
        "hex": "#eafbd7"
      }
    },
    "warning": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          0.714,
          0.047
        ],
        "hex": "#ffb60c"
      }
    },
    "warning-strong": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.718,
          0.467,
          0.024
        ],
        "hex": "#b77706"
      }
    },
    "warning-surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          0.965,
          0.808
        ],
        "hex": "#fff6ce"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xxs": {
      "$value": {
        "value": 2,
        "unit": "px"
      }
    },
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 32,
        "unit": "px"
      }
    },
    "xxl": {
      "$value": {
        "value": 48,
        "unit": "px"
      }
    },
    "xxxl": {
      "$value": {
        "value": 64,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "min": {
      "$value": {
        "value": 2,
        "unit": "px"
      }
    },
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 6,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "full": {
      "$value": {
        "value": 100,
        "unit": "px"
      }
    }
  },
  "typography": {
    "display": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 4,
          "unit": "rem"
        },
        "fontWeight": 700
      }
    },
    "h1": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 2.5,
          "unit": "rem"
        },
        "fontWeight": 700
      }
    },
    "h2": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 2,
          "unit": "rem"
        },
        "fontWeight": 700
      }
    },
    "h3": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1.5,
          "unit": "rem"
        },
        "fontWeight": 700
      }
    },
    "h4": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1.25,
          "unit": "rem"
        },
        "fontWeight": 700
      }
    },
    "body-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1.25,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "body-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "body-sm": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 0.875,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "label": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 0.875,
          "unit": "rem"
        },
        "fontWeight": 500
      }
    },
    "caption": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 0.75,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    }
  }
}
